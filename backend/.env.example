# Google Cloud
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Cloud Storage
GCS_BUCKET_NAME=sportsguard-assets

# Gemini model on Vertex AI
GEMINI_MODEL=gemini-2.5-flash

# Port (Cloud Run sets this automatically)
PORT=8080

# CORS — set to your Firebase Hosting URL in production
ALLOWED_ORIGIN=https://sportsguard-ai.web.app

# Optional: explicit service account key path (not needed on Cloud Run with attached SA)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
